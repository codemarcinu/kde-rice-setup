# ── Profiles ────────────────────────────────────────────────
cmd_profile() {
    case "${1:-help}" in
        desktop)
            echo -e "\n${BOLD}  Profile: Desktop (2 monitory)${NC}\n"

            # Hot corners — mysz jest precyzyjna
            cmd_hotcorners desktop

            # Night Color — ochrona oczu
            cmd_nightcolor on 3800

            # Skroty klawiszowe
            cmd_shortcuts defaults

            # Clipboard 50 wpisow
            cmd_clipboard set 50

            # Splash off — szybki boot
            cmd_splash off

            # Lock screen = tapeta pulpitu
            cmd_lockscreen wallpaper

            # Efekty — pelna moc na stacjonarnym GPU
            cmd_effects blur 10
            cmd_effects corners 10
            cmd_effects dim 15

            # Ikony wieksze — duze monitory
            cmd_icons all 28

            # Animacje — plynne ale nie za wolne
            cmd_animations speed 0.25

            # Dock — duzy, autohide
            cmd_panel autohide dock true
            cmd_panel height dock 60

            # 4 pulpity na 2 monitory
            cmd_desktops set 4

            echo ""
            ok "Profile desktop zastosowany"
            info "Wyloguj/zaloguj dla pelnej aktywacji"
            ;;
        laptop)
            echo -e "\n${BOLD}  Profile: Laptop (touchpad)${NC}\n"

            # Hot corners OFF — touchpad wywoluje przypadkowo
            cmd_hotcorners off

            # Gesty touchpada zamiast hot corners
            cmd_touchpad on
            cmd_touchpad gestures

            # Night Color — laptop czesto uzywany wieczorem
            cmd_nightcolor on 3500

            # Skroty klawiszowe
            cmd_shortcuts defaults

            # Clipboard 50 wpisow
            cmd_clipboard set 50

            # Splash off
            cmd_splash off

            # Lock screen = tapeta pulpitu
            cmd_lockscreen wallpaper

            # Efekty — lzejsze (oszczednosc baterii)
            cmd_effects blur 6
            cmd_effects corners 8
            cmd_effects dim 10

            # Ikony mniejsze — maly ekran
            cmd_icons all 22

            # Animacje szybsze — mniej GPU
            cmd_animations speed 0.15

            # Dock — mniejszy, autohide
            cmd_panel autohide dock true
            cmd_panel height dock 48

            # 3 pulpity
            cmd_desktops set 3

            echo ""
            ok "Profile laptop zastosowany"
            info "Wyloguj/zaloguj dla pelnej aktywacji"
            ;;
        info)
            echo -e "${BOLD}Profile:${NC}"
            echo "  desktop — stacjonarny z 2 monitorami"
            echo "    hot corners, pelne efekty, duze ikony, 4 pulpity"
            echo "  laptop — laptop z touchpadem"
            echo "    gesty, lekkie efekty, male ikony, 3 pulpity"
            ;;
        help|*) cat <<'EOF'
  profile desktop    stacjonarny: hot corners, pelne efekty, 4 pulpity
  profile laptop     laptop: gesty, lekkie efekty, 3 pulpity
  profile info       porownanie profili
EOF
            ;;
    esac
}

# ── System ──────────────────────────────────────────────────
cmd_restart() {
    info "Restartowanie plasmashell..."
    kquitapp6 plasmashell 2>/dev/null || true
    sleep 2
    plasmashell 2>/dev/null &
    sleep 4
    _dbus_panel "
    var p = panels();
    for (var i = 0; i < p.length; i++)
        if (p[i].location == 'bottom') {
            p[i].alignment = 'center';
            p[i].lengthMode = 'fit';
        }"
    ok "Plasmashell zrestartowany"
}

cmd_backup() {
    local dir="${1:-$SCRIPT_DIR/backup-$(date +%Y%m%d-%H%M%S)}"
    mkdir -p "$dir"
    for f in plasma-org.kde.plasma.desktop-appletsrc plasmashellrc kwinrc kdeglobals kcminputrc; do
        cp ~/.config/$f "$dir/" 2>/dev/null || true
    done
    cp ~/.config/kitty/kitty.conf "$dir/" 2>/dev/null || true
    cp ~/.config/starship.toml "$dir/" 2>/dev/null || true
    cp ~/.config/Kvantum/kvantum.kvconfig "$dir/" 2>/dev/null || true
    ok "Backup: $dir"
}

cmd_export() {
    info "Eksport do $SCRIPT_DIR/configs/..."
    cp ~/.config/plasma-org.kde.plasma.desktop-appletsrc "$SCRIPT_DIR/configs/plasma-appletsrc"
    cp ~/.config/plasmashellrc "$SCRIPT_DIR/configs/plasmashellrc"
    cp ~/.config/kitty/kitty.conf "$SCRIPT_DIR/configs/kitty.conf"
    cp ~/.config/starship.toml "$SCRIPT_DIR/configs/starship.toml"
    cp ~/.local/share/wallpapers/rice-wallpaper.png "$SCRIPT_DIR/wallpaper/wallpaper.png" 2>/dev/null || true
    ok "Wyeksportowano"
}

