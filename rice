# ── Lock Screen ─────────────────────────────────────────────
cmd_lockscreen() {
    case "${1:-help}" in
        wallpaper)
            local wp="${2:-$HOME/.local/share/wallpapers/rice-wallpaper.png}"
            [[ ! -f "$wp" ]] && { fail "Brak tapety: $wp"; return 1; }
