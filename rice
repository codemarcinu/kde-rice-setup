# ── Night Color ─────────────────────────────────────────────
cmd_nightcolor() {
    case "${1:-help}" in
        on)
            local temp="${2:-3800}"
            _kwrite --file kwinrc --group NightColor --key Active true
            _kwrite --file kwinrc --group NightColor --key Mode "Automatic"
            _kwrite --file kwinrc --group NightColor --key NightTemperature "$temp"
            qdbus6 org.kde.KWin /KWin reconfigure 2>/dev/null || true
            ok "Night Color: ON (${temp}K wieczorem)"
            ;;
        off)
            _kwrite --file kwinrc --group NightColor --key Active false
            qdbus6 org.kde.KWin /KWin reconfigure 2>/dev/null || true
            ok "Night Color: OFF"
            ;;
        temp)
            _kwrite --file kwinrc --group NightColor --key NightTemperature "${2:-3800}"
