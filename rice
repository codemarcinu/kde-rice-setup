# ── Touchpad ────────────────────────────────────────────────
cmd_touchpad() {
    case "${1:-help}" in
        on)
            _kwrite --file kcminputrc --group Libinput --group "2" --group "7" --group "SynPS/2 Synaptics TouchPad" \
                --key NaturalScroll true
            _kwrite --file kcminputrc --group Libinput --group "2" --group "7" --group "SynPS/2 Synaptics TouchPad" \
                --key TapToClick true
            # Gestures via libinput — KDE auto-detects touchpad
            _kwrite --file kwinrc --group Plugins --key overviewEnabled true
            _kwrite --file kwinrc --group Input --key TouchpadScrollMethod "TwoFingerScrolling"
            qdbus6 org.kde.KWin /KWin reconfigure 2>/dev/null || true
            ok "Touchpad: natural scroll, tap-to-click"
            ;;
        gestures)
            # Plasma 6 built-in gestures
            _kwrite --file kwinrc --group Plugins --key overviewEnabled true
            # 4-finger swipe up = Overview (built-in in Plasma 6)
            # 3-finger swipe left/right = switch desktop (built-in)
            qdbus6 org.kde.KWin /KWin reconfigure 2>/dev/null || true
            ok "Gesty: 4 palce gora=Overview, 3 palce lewo/prawo=pulpit"
            info "Gesty sa wbudowane w Plasma 6 (libinput)"
            ;;
        off)
            _kwrite --file kwinrc --group Input --key TouchpadScrollMethod "NoScrolling"
            ok "Touchpad scroll: wylaczony"
            ;;
        info)
            echo -e "${BOLD}Touchpad:${NC}"
            echo "  Natural scroll: $(_kread --file kcminputrc --group Libinput --group 2 --group 7 --group "SynPS/2 Synaptics TouchPad" --key NaturalScroll)"
            echo "  Tap to click:   $(_kread --file kcminputrc --group Libinput --group 2 --group 7 --group "SynPS/2 Synaptics TouchPad" --key TapToClick)"
            ;;
        help|*) cat <<'EOF'
  touchpad on              natural scroll + tap-to-click
  touchpad gestures        wlacz gesty (overview, switch desktop)
  touchpad off             wylacz scroll
  touchpad info            pokaz ustawienia
EOF
            ;;
    esac
}

