                && echo -e "  ${GREEN}ON${NC}  ${temp:-4500}K" \
                || echo -e "  ${DIM}OFF${NC}"
            ;;
        help|*) cat <<'EOF'
  nightcolor on [temp]       wlacz (domyslnie 3800K)
