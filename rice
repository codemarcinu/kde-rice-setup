            ok "Night Color temp: ${2:-3800}K"
            ;;
        info)
            echo -e "${BOLD}Night Color:${NC}"
            local active; active=$(_kread --file kwinrc --group NightColor --key Active)
            local temp; temp=$(_kread --file kwinrc --group NightColor --key NightTemperature)
