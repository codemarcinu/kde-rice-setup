# ── Router ──────────────────────────────────────────────────
case "${1:-help}" in
    wallpaper)    shift; cmd_wallpaper "$@" ;;
    theme)        shift; cmd_theme "$@" ;;
    panel)        shift; cmd_panel "$@" ;;
    dock)         shift; cmd_dock "$@" ;;
    effects)      shift; cmd_effects "$@" ;;
    icons)        shift; cmd_icons "$@" ;;
    transparency) shift; cmd_transparency "$@" ;;
    fonts)        shift; cmd_fonts "$@" ;;
    terminal)     shift; cmd_terminal "$@" ;;
    monitor)      shift; cmd_monitor "$@" ;;
    cursor)       shift; cmd_cursor "$@" ;;
    desktops)     shift; cmd_desktops "$@" ;;
    animations)   shift; cmd_animations "$@" ;;
    buttons)      shift; cmd_buttons "$@" ;;
    nightcolor)   shift; cmd_nightcolor "$@" ;;
    hotcorners)   shift; cmd_hotcorners "$@" ;;
    shortcuts)    shift; cmd_shortcuts "$@" ;;
    clipboard)    shift; cmd_clipboard "$@" ;;
    splash)       shift; cmd_splash "$@" ;;
    lockscreen)   shift; cmd_lockscreen "$@" ;;
    touchpad)     shift; cmd_touchpad "$@" ;;
    preset)       shift; cmd_preset "$@" ;;
    profile)      shift; cmd_profile "$@" ;;
    restart)      shift; cmd_restart ;;
    backup)       shift; cmd_backup "$@" ;;
    export)       shift; cmd_export ;;
    status)       cmd_status ;;
    install)      cmd_install_cli ;;
    -v|--version) echo "rice v${VERSION}" ;;
    help|--help|-h) cmd_help ;;
    *)
        fail "Nieznana komenda: $1"
        cmd_help
        exit 1
        ;;
esac
