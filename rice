# ── Hot Corners ─────────────────────────────────────────────
cmd_hotcorners() {
    case "${1:-help}" in
        desktop)
            # Top-left: Overview, Top-right: Show Desktop
            _kwrite --file kwinrc --group Effect-overview --key BorderActivate 7
            _kwrite --file kwinrc --group ElectricBorders --key TopRight "ShowDesktop"
            qdbus6 org.kde.KWin /KWin reconfigure 2>/dev/null || true
            ok "Hot corners: lewy-gorny=Overview, prawy-gorny=Pulpit"
            ;;
        overview)
            _kwrite --file kwinrc --group Effect-overview --key BorderActivate 7
            qdbus6 org.kde.KWin /KWin reconfigure 2>/dev/null || true
            ok "Hot corner: lewy-gorny=Overview"
            ;;
        off)
            _kwrite --file kwinrc --group Effect-overview --key BorderActivate 0
            _kwrite --file kwinrc --group ElectricBorders --key TopLeft "None"
            _kwrite --file kwinrc --group ElectricBorders --key TopRight "None"
            _kwrite --file kwinrc --group ElectricBorders --key BottomLeft "None"
            _kwrite --file kwinrc --group ElectricBorders --key BottomRight "None"
            qdbus6 org.kde.KWin /KWin reconfigure 2>/dev/null || true
            ok "Hot corners: wylaczone"
            ;;
        info)
            echo -e "${BOLD}Hot corners:${NC}"
            local ov; ov=$(_kread --file kwinrc --group Effect-overview --key BorderActivate)
            local tr; tr=$(_kread --file kwinrc --group ElectricBorders --key TopRight)
            [[ "$ov" == "7" ]] && echo "  Lewy-gorny:  Overview" || echo "  Lewy-gorny:  -"
            [[ -n "$tr" && "$tr" != "None" ]] && echo "  Prawy-gorny: $tr" || echo "  Prawy-gorny: -"
            ;;
        help|*) cat <<'EOF'
  hotcorners desktop         overview + pokaz pulpit
  hotcorners overview        tylko overview (lewy-gorny)
  hotcorners off             wylacz wszystkie
  hotcorners info            pokaz ustawienia
