# ── Shortcuts ───────────────────────────────────────────────
cmd_shortcuts() {
    case "${1:-help}" in
        defaults)
            # Meta+E = Dolphin, Meta+T = kitty, Meta+B = browser
            kwriteconfig6 --file kglobalshortcutsrc --group "org.kde.dolphin.desktop" --key "_launch" "Meta+E,Meta+E,Dolphin"
            kwriteconfig6 --file kglobalshortcutsrc --group "kitty.desktop" --key "_launch" "Meta+T,Meta+T,kitty"

            # Detect browser
            local browser="brave-browser.desktop"
            [[ ! -f "/usr/share/applications/$browser" ]] && browser="firefox.desktop"
            kwriteconfig6 --file kglobalshortcutsrc --group "$browser" --key "_launch" "Meta+B,Meta+B,Browser"

            # Meta+D = Overview
            kwriteconfig6 --file kglobalshortcutsrc --group kwin --key "Overview" "Meta+D,Meta+W,Toggle Overview"

            # Meta+L = Lock screen
            kwriteconfig6 --file kglobalshortcutsrc --group ksmserver --key "Lock Session" "Meta+L,Meta+L,Zablokuj sesje"

            ok "Skroty: Meta+E=Pliki  Meta+T=Terminal  Meta+B=Przegladarka"
            ok "        Meta+D=Overview  Meta+L=Blokada"
            info "Wyloguj/zaloguj dla pelnej aktywacji"
            ;;
        info)
            echo -e "${BOLD}Skroty klawiszowe:${NC}"
            echo "  Meta+E  Dolphin"
            echo "  Meta+T  kitty"
            echo "  Meta+B  Przegladarka"
            echo "  Meta+D  Overview"
            echo "  Meta+L  Blokada ekranu"
            ;;
        help|*) cat <<'EOF'
  shortcuts defaults         ustaw standardowe skroty
  shortcuts info             pokaz skroty
EOF
            ;;
    esac
}

