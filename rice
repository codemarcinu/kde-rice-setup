                --key Image "file://$wp"
            _kwrite --file kscreenlockerrc --group Greeter --group Wallpaper --group org.kde.image --group General \
                --key PreviewImage "file://$wp"
            ok "Lock screen: tapeta zsynchronizowana"
            ;;
