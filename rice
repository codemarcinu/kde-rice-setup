#!/bin/bash
# rice — KDE Plasma 6 rice management CLI
# https://github.com/codemarcinu/kde-rice-setup

set -euo pipefail

VERSION="2.1.0"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# ── Colors ──────────────────────────────────────────────────
RED='\033[0;31m'    GREEN='\033[0;32m'  YELLOW='\033[1;33m'
BLUE='\033[0;34m'   CYAN='\033[0;36m'   MAGENTA='\033[0;35m'
BOLD='\033[1m'      DIM='\033[2m'       NC='\033[0m'

info()  { echo -e "  ${BLUE}→${NC} $1"; }
ok()    { echo -e "  ${GREEN}✓${NC} $1"; }
warn()  { echo -e "  ${YELLOW}!${NC} $1"; }
fail()  { echo -e "  ${RED}✗${NC} $1"; }

_dbus_panel() {
    qdbus6 org.kde.plasmashell /PlasmaShell org.kde.PlasmaShell.evaluateScript "$1" 2>/dev/null
}

_kwrite() { kwriteconfig6 "$@"; }
_kread()  { kreadconfig6 "$@"; }

# ── Wallpaper ───────────────────────────────────────────────
cmd_wallpaper() {
    case "${1:-help}" in
        set)
            [[ -z "${2:-}" ]] && { echo "Uzycie: rice wallpaper set <plik>"; return 1; }
            [[ ! -f "$2" ]] && { fail "Plik nie istnieje: $2"; return 1; }
            mkdir -p ~/.local/share/wallpapers
            cp "$2" ~/.local/share/wallpapers/rice-wallpaper.png
            _dbus_panel "
            var d = desktops();
            for (var i = 0; i < d.length; i++) {
                d[i].wallpaperPlugin = 'org.kde.image';
                d[i].currentConfigGroup = ['Wallpaper','org.kde.image','General'];
                d[i].writeConfig('Image','file://$HOME/.local/share/wallpapers/rice-wallpaper.png');
            }"
            ok "Tapeta: $2"
            ;;
        darken)
            local f="${HOME}/.local/share/wallpapers/rice-wallpaper.png" pct="${2:-10}"
            [[ ! -f "$f" ]] && { fail "Brak tapety"; return 1; }
            magick "$f" -modulate $((100-pct)),100,100 "$f"
            cmd_wallpaper set "$f"
            ok "Przyciemniono o ${pct}%"
            ;;
        lighten)
            local f="${HOME}/.local/share/wallpapers/rice-wallpaper.png" pct="${2:-10}"
            [[ ! -f "$f" ]] && { fail "Brak tapety"; return 1; }
            magick "$f" -modulate $((100+pct)),100,100 "$f"
            cmd_wallpaper set "$f"
            ok "Rozjasniono o ${pct}%"
            ;;
        blur)
            local f="${HOME}/.local/share/wallpapers/rice-wallpaper.png" r="${2:-5}"
            [[ ! -f "$f" ]] && { fail "Brak tapety"; return 1; }
            magick "$f" -blur "0x${r}" "$f"
            cmd_wallpaper set "$f"
            ok "Blur radius=${r}"
            ;;
        reset)
            [[ -f "$SCRIPT_DIR/wallpaper/wallpaper.png" ]] \
                && cmd_wallpaper set "$SCRIPT_DIR/wallpaper/wallpaper.png" \
                || fail "Brak domyslnej tapety"
            ;;
        help|*) cat <<'EOF'
  wallpaper set <plik>        ustaw tapete
  wallpaper darken [%]        przyciemnij (domyslnie 10%)
  wallpaper lighten [%]       rozjasnij (domyslnie 10%)
  wallpaper blur [radius]     rozmyj (domyslnie 5)
  wallpaper reset             przywroc domyslna
EOF
            ;;
    esac
}

# ── Theme ───────────────────────────────────────────────────
cmd_theme() {
    case "${1:-help}" in
        dark)
            plasma-apply-desktoptheme Qogir-dark
            plasma-apply-colorscheme QogirManjaroDark
            /usr/lib/plasma-changeicons Papirus-Dark 2>/dev/null || true
            _kwrite --file kwinrc --group org.kde.kdecoration2 --key theme "__aurorae__svg__Qogir-dark"
            _kwrite --file kdeglobals --group KDE --key widgetStyle "kvantum"
            mkdir -p ~/.config/Kvantum
            echo -e "[General]\ntheme=Qogir-dark" > ~/.config/Kvantum/kvantum.kvconfig
            local theme_dir=~/.local/share/plasma/desktoptheme/Qogir-dark
            local backup_dir="${theme_dir}-rice-backup"
            # Backup originals once; restore before applying for idempotency
            [[ -d "$theme_dir" ]] && {
                [[ ! -d "$backup_dir" ]] && cp -a "$theme_dir" "$backup_dir"
                cp -a "$backup_dir"/. "$theme_dir"
                find "$theme_dir" -name '*.svg' -exec sed -i \
                    -e 's/color:#eff0f1/color:#282a33/g' -e 's/stop-color:#eff0f1/stop-color:#282a33/g' \
                    -e 's/color:#fcfcfc/color:#30333d/g'  -e 's/stop-color:#fcfcfc/stop-color:#30333d/g' \
                    -e 's/color:#31363b/color:#d3dae3/g'  -e 's/stop-color:#31363b/stop-color:#d3dae3/g' \
                    {} + 2>/dev/null || true
            }
            qdbus6 org.kde.KWin /KWin reconfigure 2>/dev/null || true
            ok "Motyw ciemny (Qogir-dark)"
            ;;
        light)
            plasma-apply-desktoptheme Qogir-light
            plasma-apply-colorscheme QogirLight
            /usr/lib/plasma-changeicons Papirus-Light 2>/dev/null || true
            _kwrite --file kwinrc --group org.kde.kdecoration2 --key theme "__aurorae__svg__Qogir"
            mkdir -p ~/.config/Kvantum
            echo -e "[General]\ntheme=Qogir-light" > ~/.config/Kvantum/kvantum.kvconfig
            qdbus6 org.kde.KWin /KWin reconfigure 2>/dev/null || true
            ok "Motyw jasny (Qogir-light)"
            ;;
        info)
            echo -e "${BOLD}Motyw:${NC}"
            echo "  Plasma:     $(_kread --file plasmarc --group Theme --key name)"
            echo "  Kolory:     $(_kread --file kdeglobals --group General --key ColorScheme)"
            echo "  Ikony:      $(_kread --file kdeglobals --group Icons --key Theme)"
            echo "  Dekoracja:  $(_kread --file kwinrc --group org.kde.kdecoration2 --key theme)"
            echo "  Kursor:     $(_kread --file kcminputrc --group Mouse --key cursorTheme)"
            echo "  Kvantum:    $(grep theme= ~/.config/Kvantum/kvantum.kvconfig 2>/dev/null | cut -d= -f2)"
            ;;
        help|*) echo "  theme dark|light|info" ;;
    esac
}

# ── Panel ───────────────────────────────────────────────────
_panel_location() { [[ "${1:-dock}" == "top" ]] && echo "top" || echo "bottom"; }

_find_panel_id() {
    local target cfg=~/.config/plasma-org.kde.plasma.desktop-appletsrc
    case "${1:-bottom}" in top) target=3 ;; *) target=4 ;; esac
    awk -v t="$target" 'BEGIN { loc="location=" t }
        match($0, /^\[Containments\]\[([0-9]+)\]$/, m) { id=m[1]; panel=0 }
        /^plugin=org\.kde\.panel$/ { panel=1 }
        panel && $0 == loc { print id; exit }
    ' "$cfg"
}

_panel_id() {
    local loc
    case "${1:-dock}" in top) loc="top" ;; *) loc="bottom" ;; esac
    local id; id=$(_find_panel_id "$loc")
    [[ -z "$id" ]] && { fail "Nie znaleziono panelu: $loc"; return 1; }
    echo "$id"
}

_is_num() { [[ "$1" =~ ^[0-9]+(\.[0-9]+)?$ ]]; }

_dock_launchers() {
    local panel_id cfg=~/.config/plasma-org.kde.plasma.desktop-appletsrc
    panel_id=$(_find_panel_id bottom) || return 1
    awk -v pid="$panel_id" '
        $0 ~ "^\\[Containments\\]\\[" pid "\\]" { in_panel=1 }
        /^\[/ && $0 !~ "^\\[Containments\\]\\[" pid "\\]" { in_panel=0 }
        in_panel && /^launchers=/ { sub(/^launchers=/, ""); print; exit }
    ' "$cfg"
}

cmd_panel() {
    case "${1:-help}" in
        opacity)
            local val="${2:-adaptive}"
            case "$val" in
                adaptive|auto) val=0 ;; opaque|solid) val=1 ;; translucent) val=2 ;;
            esac
            local pid; pid=$(_panel_id top) || return 1
            _kwrite --file plasmashellrc --group PlasmaViews --group "Panel $pid" --key panelOpacity "$val"
            ok "Panel opacity: $val (0=adaptive 1=opaque 2=translucent)"
            info "Restart wymagany: rice restart"
            ;;
        thickness)
            [[ -z "${3:-}" ]] && { echo "Uzycie: rice panel thickness <top|dock> <px>"; return 1; }
            _kwrite --file plasmashellrc --group PlasmaViews --group "Panel $(_panel_id "$2")" --group Defaults --key thickness "$3"
            ok "Panel $2 thickness: ${3}px"
            info "Restart wymagany: rice restart"
            ;;
        floating)
            local val=1; [[ "${3:-true}" =~ ^(false|off|0)$ ]] && val=0
            _kwrite --file plasmashellrc --group PlasmaViews --group "Panel $(_panel_id "${2:-dock}")" --key floating "$val"
            ok "Panel ${2:-dock} floating: $val"
            info "Restart wymagany: rice restart"
            ;;
        autohide)
            local hiding="autohide"; [[ "${3:-true}" =~ ^(false|off|0)$ ]] && hiding="none"
            _dbus_panel "
            var p = panels();
            for (var i = 0; i < p.length; i++)
                if (p[i].location == '$(_panel_location "${2:-dock}")')
                    p[i].hiding = '$hiding';"
            ok "Panel ${2:-dock} autohide: $hiding"
            ;;
        height)
            _dbus_panel "
            var p = panels();
            for (var i = 0; i < p.length; i++)
                if (p[i].location == '$(_panel_location "${2:-dock}")')
                    p[i].height = ${3:-48};"
            ok "Panel ${2:-dock} height: ${3:-48}px"
            ;;
        help|*) cat <<'EOF'
  panel opacity <adaptive|opaque|translucent>
  panel thickness <top|dock> <px>
  panel floating <top|dock> <true|false>
  panel autohide <top|dock> <true|false>
  panel height <top|dock> <px>
EOF
            ;;
    esac
}

# ── Dock ────────────────────────────────────────────────────
cmd_dock() {
    local cfg=~/.config/plasma-org.kde.plasma.desktop-appletsrc
    case "${1:-help}" in
        add)
            [[ -z "${2:-}" ]] && { echo "Uzycie: rice dock add <app.desktop>"; return 1; }
            [[ ! -f "/usr/share/applications/$2" ]] && { fail "Nie znaleziono: $2"; return 1; }
            local current; current=$(_dock_launchers)
            [[ -z "$current" ]] && { fail "Nie znaleziono launchera w konfiguracji"; return 1; }
            echo "$current" | grep -q "$2" && { warn "$2 juz w docku"; return 0; }
            sed -i "0,/^launchers=/{s|^launchers=.*|launchers=${current},applications:${2}|}" "$cfg"
            ok "Dodano: $2"
            info "Restart wymagany: rice restart"
            ;;
        remove)
            [[ -z "${2:-}" ]] && { echo "Uzycie: rice dock remove <app.desktop>"; return 1; }
            sed -i "0,/^launchers=/{s|,applications:${2}||; s|applications:${2},||; s|applications:${2}||}" "$cfg"
            ok "Usunieto: $2"
            info "Restart wymagany: rice restart"
            ;;
        list)
            echo -e "${BOLD}Dock:${NC}"
            _dock_launchers | tr ',' '\n' | while read -r l; do
                [[ -n "$l" ]] && echo "  $l"
            done
            ;;
        super)
            cmd_panel autohide dock true
            _kwrite --file kwinrc --group ModifierOnlyShortcuts --key Meta \
                "org.kde.plasmashell,/PlasmaShell,org.kde.PlasmaShell,evaluateScript,var p=panels();for(var i=0;i<p.length;i++)if(p[i].location=='bottom'){var h=p[i].hiding;p[i].hiding=h=='autohide'?'none':'autohide'}"
            qdbus6 org.kde.KWin /KWin reconfigure 2>/dev/null || true
            ok "Super = toggle dock"
            warn "Super nie otwiera juz launchera — rice dock super-off aby przywrocic"
            ;;
        super-off)
            _kwrite --file kwinrc --group ModifierOnlyShortcuts --key Meta \
                "org.kde.plasmashell,/PlasmaShell,org.kde.PlasmaShell,activateLauncherMenu"
            qdbus6 org.kde.KWin /KWin reconfigure 2>/dev/null || true
            ok "Super = launcher (domyslny)"
            ;;
        help|*) cat <<'EOF'
  dock add <app.desktop>      dodaj do docka
  dock remove <app.desktop>   usun z docka
  dock list                   pokaz zawartosc
  dock super                  Super = toggle dock
  dock super-off              przywroc Super = launcher
EOF
            ;;
    esac
}

# ── Effects ─────────────────────────────────────────────────
cmd_effects() {
    case "${1:-help}" in
        blur)
            local s="${2:-8}"
            _is_num "$s" || { fail "Wartosc musi byc liczba: $s"; return 1; }
            _kwrite --file kwinrc --group Plugins --key blurEnabled true
            _kwrite --file kwinrc --group Effect-blur --key BlurStrength "$s"
            _kwrite --file kwinrc --group Effect-blur --key NoiseStrength 0
            qdbus6 org.kde.KWin /KWin reconfigure 2>/dev/null || true
            ok "Blur: $s/15"
            ;;
        blur-off)
            _kwrite --file kwinrc --group Plugins --key blurEnabled false
            qdbus6 org.kde.KWin /KWin reconfigure 2>/dev/null || true
            ok "Blur wylaczony"
            ;;
        corners)
            local s="${2:-10}"
            _is_num "$s" || { fail "Wartosc musi byc liczba: $s"; return 1; }
            _kwrite --file kwinrc --group Plugins --key kwin_effect_rounded_cornersEnabled true
            _kwrite --file kwinrc --group Effect-kwin_effect_rounded_corners --key Size "$s"
            qdbus6 org.kde.KWin /KWin reconfigure 2>/dev/null || true
            ok "Zaokraglone rogi: ${s}px"
            ;;
        corners-off)
            _kwrite --file kwinrc --group Plugins --key kwin_effect_rounded_cornersEnabled false
            qdbus6 org.kde.KWin /KWin reconfigure 2>/dev/null || true
            ok "Zaokraglone rogi wylaczone"
            ;;
        dim)
            local s="${2:-15}"
            _is_num "$s" || { fail "Wartosc musi byc liczba: $s"; return 1; }
            _kwrite --file kwinrc --group Plugins --key diminactiveEnabled true
            _kwrite --file kwinrc --group Effect-diminactive --key Strength "$s"
            qdbus6 org.kde.KWin /KWin reconfigure 2>/dev/null || true
            ok "Dim inactive: ${s}%"
            ;;
        dim-off)
            _kwrite --file kwinrc --group Plugins --key diminactiveEnabled false
            qdbus6 org.kde.KWin /KWin reconfigure 2>/dev/null || true
            ok "Dim inactive wylaczony"
            ;;
        status|info)
            echo -e "${BOLD}Efekty KWin:${NC}"
            for effect in blur kwin_effect_rounded_corners diminactive; do
                local enabled name
                enabled=$(_kread --file kwinrc --group Plugins --key "${effect}Enabled")
                case "$effect" in
                    blur) name="Blur" ;;
                    kwin_effect_rounded_corners) name="Rounded Corners" ;;
                    diminactive) name="Dim Inactive" ;;
                esac
                [[ "$enabled" == "true" ]] \
                    && echo -e "  ${GREEN}ON${NC}  $name" \
                    || echo -e "  ${DIM}OFF${NC} $name"
            done
            ;;
        help|*) cat <<'EOF'
  effects blur [1-15]         blur (domyslnie 8)
  effects blur-off            wylacz blur
  effects corners [px]        zaokraglone rogi (domyslnie 10)
  effects corners-off         wylacz zaokraglenia
  effects dim [1-100]         dim inactive (domyslnie 15%)
  effects dim-off             wylacz dim
  effects status              pokaz status
EOF
            ;;
    esac
}

# ── Icons ───────────────────────────────────────────────────
cmd_icons() {
    case "${1:-help}" in
        desktop)  _kwrite --file kdeglobals --group DesktopIcons     --key Size "${2:-48}"; ok "Pulpit: ${2:-48}px" ;;
        panel)    _kwrite --file kdeglobals --group PanelIcons       --key Size "${2:-22}"; ok "Panel: ${2:-22}px" ;;
        toolbar)  _kwrite --file kdeglobals --group ToolbarIcons     --key Size "${2:-22}"
                  _kwrite --file kdeglobals --group MainToolbarIcons --key Size "${2:-22}"; ok "Toolbar: ${2:-22}px" ;;
        small)    _kwrite --file kdeglobals --group SmallIcons       --key Size "${2:-16}"; ok "Male: ${2:-16}px" ;;
        dialog)   _kwrite --file kdeglobals --group DialogIcons      --key Size "${2:-32}"; ok "Dialogi: ${2:-32}px" ;;
        all)
            local s="${2:-22}"
            cmd_icons desktop "$((s * 2))"
            cmd_icons panel "$s"
            cmd_icons toolbar "$s"
            cmd_icons small "$((s - 6 > 12 ? s - 6 : 12))"
            cmd_icons dialog "$((s + 10))"
            ;;
        info)
            echo -e "${BOLD}Ikony:${NC}"
            echo "  Pulpit:   $(_kread --file kdeglobals --group DesktopIcons --key Size)px"
            echo "  Panel:    $(_kread --file kdeglobals --group PanelIcons --key Size)px"
            echo "  Toolbar:  $(_kread --file kdeglobals --group ToolbarIcons --key Size)px"
            echo "  Male:     $(_kread --file kdeglobals --group SmallIcons --key Size)px"
            echo "  Dialogi:  $(_kread --file kdeglobals --group DialogIcons --key Size)px"
            ;;
        help|*) cat <<'EOF'
  icons desktop|panel|toolbar|small|dialog [px]
  icons all [px]              ustaw proporcjonalnie
  icons info                  pokaz rozmiary
EOF
            ;;
    esac
}

# ── Transparency ────────────────────────────────────────────
cmd_transparency() {
    case "${1:-help}" in
        panel)
            local pid; pid=$(_panel_id top) || return 1
            _kwrite --file plasmashellrc --group PlasmaViews --group "Panel $pid" --key panelOpacity 2
            ok "Panel: translucent"
            info "Restart wymagany: rice restart"
            ;;
        dock)
            local pid; pid=$(_panel_id dock) || return 1
            _kwrite --file plasmashellrc --group PlasmaViews --group "Panel $pid" --key panelOpacity 2
            ok "Dock: translucent"
            info "Restart wymagany: rice restart"
            ;;
        kitty)
            local v="${2:-0.85}"
            [[ -f ~/.config/kitty/kitty.conf ]] && sed -i "s/^background_opacity .*/background_opacity $v/" ~/.config/kitty/kitty.conf
            ok "Kitty opacity: $v"
            info "Zrestartuj kitty"
            ;;
        info)
            echo -e "${BOLD}Przezroczystosc:${NC}"
            local pid; pid=$(_panel_id top) || return 1
            local p; p=$(_kread --file plasmashellrc --group PlasmaViews --group "Panel $pid" --key panelOpacity)
            case "$p" in 0) p="adaptive" ;; 1) p="opaque" ;; 2) p="translucent" ;; esac
            echo "  Panel:  $p"
            [[ -f ~/.config/kitty/kitty.conf ]] && echo "  Kitty:  $(grep '^background_opacity' ~/.config/kitty/kitty.conf | awk '{print $2}')"
            ;;
        help|*) cat <<'EOF'
  transparency panel          panel translucent
  transparency dock           dock translucent
  transparency kitty [0-1]    kitty opacity (domyslnie 0.85)
  transparency info           pokaz ustawienia
EOF
            ;;
    esac
}

# ── Fonts ───────────────────────────────────────────────────
cmd_fonts() {
    case "${1:-help}" in
        set)
            local f="${2:-IBM Plex Mono}" s="${3:-10}"
            _kwrite --file kdeglobals --group General --key font "$f,$s,-1,5,50,0,0,0,0,0"
            _kwrite --file kdeglobals --group General --key menuFont "$f,$s,-1,5,50,0,0,0,0,0"
            _kwrite --file kdeglobals --group General --key toolBarFont "$f,$((s-1)),-1,5,50,0,0,0,0,0"
            _kwrite --file kdeglobals --group General --key smallestReadableFont "$f,$((s-2)),-1,5,50,0,0,0,0,0"
            ok "System: $f ${s}pt"
            info "Wyloguj/zaloguj"
            ;;
        terminal)
            local f="${2:-JetBrains Mono}" s="${3:-11}"
            [[ -f ~/.config/kitty/kitty.conf ]] || return
            sed -i "s/^font_family .*/font_family      $f/" ~/.config/kitty/kitty.conf
            sed -i "s/^font_size .*/font_size        $s/" ~/.config/kitty/kitty.conf
            ok "Kitty: $f ${s}pt"
            info "Zrestartuj kitty"
            ;;
        info)
            echo -e "${BOLD}Czcionki:${NC}"
            echo "  System:  $(_kread --file kdeglobals --group General --key font)"
            echo "  Fixed:   $(_kread --file kdeglobals --group General --key fixed)"
            [[ -f ~/.config/kitty/kitty.conf ]] && {
                echo "  Kitty:   $(grep '^font_family' ~/.config/kitty/kitty.conf | sed 's/font_family *//')"
                echo "  Size:    $(grep '^font_size' ~/.config/kitty/kitty.conf | sed 's/font_size *//')"
            }
            ;;
        help|*) cat <<'EOF'
  fonts set [czcionka] [pt]        systemowa (domyslnie IBM Plex Mono 10)
  fonts terminal [czcionka] [pt]   kitty (domyslnie JetBrains Mono 11)
  fonts info                       pokaz czcionki
EOF
            ;;
    esac
}

# ── Terminal ────────────────────────────────────────────────
cmd_terminal() {
    case "${1:-help}" in
        opacity)
            local v="${2:-0.92}"
            [[ -f ~/.config/kitty/kitty.conf ]] && sed -i "s/^background_opacity .*/background_opacity $v/" ~/.config/kitty/kitty.conf
            ok "Kitty opacity: $v"
            ;;
        padding)
            local v="${2:-8 12}"
            [[ -f ~/.config/kitty/kitty.conf ]] && sed -i "s/^window_padding_width .*/window_padding_width $v/" ~/.config/kitty/kitty.conf
            ok "Kitty padding: $v"
            ;;
        info)
            echo -e "${BOLD}Terminal (kitty):${NC}"
            grep -E "^(font_|background_opacity|window_padding|tab_bar|shell )" ~/.config/kitty/kitty.conf 2>/dev/null \
                | while read -r l; do echo "  $l"; done
            ;;
        help|*) cat <<'EOF'
  terminal opacity [0-1]     przezroczystosc (domyslnie 0.92)
  terminal padding [px]      padding (domyslnie "8 12")
  terminal info              pokaz konfiguracje
EOF
            ;;
    esac
}

# ── Monitor (system stats in panel) ────────────────────────
cmd_monitor() {
    case "${1:-help}" in
        add)
            _dbus_panel "
            var p = panels();
            for (var i = 0; i < p.length; i++) {
                if (p[i].location == 'top') {
                    var cpu = p[i].addWidget('org.kde.plasma.systemmonitor');
                    cpu.currentConfigGroup = ['Appearance'];
                    cpu.writeConfig('chartFace', 'org.kde.ksysguard.textonly');
                    cpu.writeConfig('title', 'CPU');
                    cpu.currentConfigGroup = ['Sensors'];
                    cpu.writeConfig('highPrioritySensorIds', '[\"cpu/all/usage\"]');
                    cpu.writeConfig('totalSensors', '[\"cpu/all/usage\"]');
                    cpu.currentConfigGroup = ['SensorColors'];
                    cpu.writeConfig('cpu/all/usage', '85,170,255');

                    var ram = p[i].addWidget('org.kde.plasma.systemmonitor');
                    ram.currentConfigGroup = ['Appearance'];
                    ram.writeConfig('chartFace', 'org.kde.ksysguard.textonly');
                    ram.writeConfig('title', 'RAM');
                    ram.currentConfigGroup = ['Sensors'];
                    ram.writeConfig('highPrioritySensorIds', '[\"memory/physical/usedPercent\"]');
                    ram.writeConfig('totalSensors', '[\"memory/physical/usedPercent\"]');
                    ram.currentConfigGroup = ['SensorColors'];
                    ram.writeConfig('memory/physical/usedPercent', '100,220,100');

                    var vram = p[i].addWidget('org.kde.plasma.systemmonitor');
                    vram.currentConfigGroup = ['Appearance'];
                    vram.writeConfig('chartFace', 'org.kde.ksysguard.textonly');
                    vram.writeConfig('title', 'VRAM');
                    vram.currentConfigGroup = ['Sensors'];
                    vram.writeConfig('highPrioritySensorIds', '[\"gpu/gpu1/usedVram\"]');
                    vram.writeConfig('totalSensors', '[\"gpu/gpu1/totalVram\"]');
                    vram.currentConfigGroup = ['SensorColors'];
                    vram.writeConfig('gpu/gpu1/usedVram', '255,170,85');
                }
            }"
            ok "Monitory: CPU, RAM, VRAM dodane do gornego panelu"
            ;;
        remove)
            _dbus_panel "
            var p = panels();
            for (var i = 0; i < p.length; i++) {
                if (p[i].location == 'top') {
                    var ws = p[i].widgets('org.kde.plasma.systemmonitor');
                    for (var j = ws.length - 1; j >= 0; j--)
                        ws[j].remove();
                }
            }"
            ok "Monitory usuniete z gornego panelu"
            ;;
        info)
            echo -e "${BOLD}Monitory (gorny panel):${NC}"
            local cfg=~/.config/plasma-org.kde.plasma.desktop-appletsrc
            local panel_id; panel_id=$(_find_panel_id top)
            if [[ -n "$panel_id" ]]; then
                grep -A5 "Containments\]\[$panel_id\].*systemmonitor" "$cfg" 2>/dev/null \
                    | grep -oP 'title=\K.*' | while read -r t; do echo "  $t"; done
                [[ $(grep -c "systemmonitor" <<< "$(grep "Containments\]\[$panel_id\]" "$cfg" 2>/dev/null)") -eq 0 ]] \
                    && echo "  (brak)"
            else
                echo "  (brak gornego panelu)"
            fi
            ;;
        help|*) cat <<'EOF'
  monitor add               dodaj CPU, RAM, VRAM do gornego panelu
  monitor remove            usun monitory z gornego panelu
  monitor info              pokaz dodane monitory
EOF
            ;;
    esac
}

